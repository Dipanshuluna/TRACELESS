# Environment Variables for Traceless Deployment
# Copy this to your Render service environment variables

# Local development defaults (avoid conflicts with Docker defaults)
# VW_BACKEND_PORT=5100
# VITE_API_BASE_URL=http://localhost:5100/api
# VITE_DEV_PORT=5176

# Backend Configuration
VW_FRONTEND_ORIGIN=https://your-frontend-app.onrender.com
VW_ATTACHED_CONTAINER_NAME=firefox-container
VW_BROWSER_URL=https://your-firefox-container.onrender.com
VW_DOWNLOAD_DIR=/tmp/downloads
VW_MAX_SESSION_MINUTES=30
VW_END_SESSION_STOPS_CONTAINER=true
VW_RESET_PATHS=/tmp/downloads

# Frontend Configuration
VITE_API_BASE_URL=https://your-backend-app.onrender.com/api

# Production Settings
NODE_ENV=production
PYTHONPATH=/opt/render/project/src/backend
